# ── Database ──
DATABASE_URL=jdbc:postgresql://localhost:5432/adminos
DB_USER=adminos
DB_PASSWORD=change_me_in_production
DB_MAX_POOL_SIZE=10

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=generate_a_256_bit_random_secret_here
JWT_ISSUER=adminos
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL_DAYS=30

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_PUBSUB_AUDIENCE=your_pubsub_push_endpoint_or_service_account

# ── Google Gmail Pub/Sub ──
GOOGLE_GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
GOOGLE_GMAIL_PUBSUB_SUBSCRIPTION=projects/your-project/subscriptions/gmail-push-sub

# ── Security ──
TOKEN_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# ── AI (Claude API) ──
CLAUDE_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Storage (Cloudflare R2 — S3 compatible) ──
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=adminos-uploads
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ── Firebase (Push Notifications) ──
FCM_SERVER_KEY=your_firebase_server_key

# ── App URLs ──
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
PORT=8080
